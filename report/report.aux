\newlabel{fig:graphs}{{1}{4}{Estimated consensus graphs per period, nodes coloured by sector and placed in a fixed sector-grouped circular layout (identical positions in every panel), node size proportional to degree. Connectivity grows toward the most recent period, and the transfer-entropy graphs are consistently denser than the Granger graphs.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Directed edge density of the consensus graphs across periods, per method and mode. On log-returns the linear and Gaussian-DI density spikes sharply in period\nobreakspace  {}2 (2019--2022, spanning the COVID crash and the 2022 sell-off), reflecting market-wide comovement, and is otherwise low; on log-prices the density is higher and evolves more smoothly, with transfer entropy densest throughout.\relax }}{5}{figure.caption.10}\protected@file@percent }
\newlabel{fig:density}{{2}{5}{Directed edge density of the consensus graphs across periods, per method and mode. On log-returns the linear and Gaussian-DI density spikes sharply in period~2 (2019--2022, spanning the COVID crash and the 2022 sell-off), reflecting market-wide comovement, and is otherwise low; on log-prices the density is higher and evolves more smoothly, with transfer entropy densest throughout.\relax }{figure.caption.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Consensus directed edge density ($\text  {edges}/870$).\relax }}{5}{table.caption.11}\protected@file@percent }
